{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build STM32",
            "type": "shell",
            "command": "make",
            "args": [
                "-j8",
                "-C",
                "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the project using the Makefile in the Debug folder."
        },
        {
            "label": "Clean STM32",
            "type": "shell",
            "command": "make",
            "args": [
                "clean",
                "-C",
                "Debug"
            ],
            "problemMatcher": [],
            "detail": "Clean the build artifacts."
        }
    ]
}
